"BFS": {
  "prefix": "bfs",
  "body": [
    "void bfs(ll start, vector<vector<ll>> &adj) {",
    "    vector<ll> vis(adj.size());",
    "    queue<ll> q;",
    "",
    "    vis[start] = 1;",
    "    q.push(start);",
    "",
    "    while (!q.empty()) {",
    "        ll u = q.front(); q.pop();",
    "        for (ll v : adj[u]) {",
    "            if (vis[v]) continue;",
    "            vis[v] = 1;",
    "            q.push(v);",
    "        }",
    "    }",
    "}"
  ],
  "description": "Breadth First Search"
