"NCR Factorial Precompute": {
  "prefix": "ncr",
  "body": [
    "const ll MOD = 998244353;",
    "const ll N = 1000005;",
    "",
    "ll fact[N];",
    "ll invFact[N];",
    "",
    "ll power(ll a, ll b) {",
    "    ll res = 1;",
    "    while (b) {",
    "        if (b & 1) res = res * a % MOD;",
    "        a = a * a % MOD;",
    "        b >>= 1;",
    "    }",
    "    return res;",
    "}",
    "",
    "void initNCR() {",
    "    fact[0] = 1;",
    "    for (ll i = 1; i < N; i++)",
    "        fact[i] = fact[i - 1] * i % MOD;",
    "",
    "    invFact[N - 1] = power(fact[N - 1], MOD - 2);",
    "",
    "    for (ll i = N - 2; i >= 0; i--)",
    "        invFact[i] = invFact[i + 1] * (i + 1) % MOD;",
    "}",
    "",
    "ll nCr(ll n, ll r) {",
    "    if (r < 0 || r > n) return 0;",
    "    return fact[n] * invFact[r] % MOD * invFact[n - r] % MOD;",
    "}"
  ],
  "description": "Factorial + inverse factorial nCr precomputation"
},
"Build SPF": {
    "scope": "cpp",
    "prefix": "buildspf",
    "body": [
        "const ll MAXN = 500000;",
        "",
        "vector<ll> spf(MAXN + 1);",
        "",
        "void build_spf() {",
        "    for (ll i = 0; i <= MAXN; i++)",
        "        spf[i] = i;",
        "",
        "    for (ll i = 2; i * i <= MAXN; i++) {",
        "        if (spf[i] == i) {",
        "            for (ll j = i * i; j <= MAXN; j += i) {",
        "                if (spf[j] == j)",
        "                    spf[j] = i;",
        "            }",
        "        }",
        "    }",
        "}"
    ],
    "description": "Build SPF array"
},
"Factorize SPF": {
    "scope": "cpp",
    "prefix": "factorize",
    "body": [
        "vector<pair<ll,ll>> factorize(ll x) {",
        "    vector<pair<ll,ll>> factors;",
        "",
        "    while (x > 1) {",
        "        ll prime = spf[x];",
        "        ll exponent = 0;",
        "",
        "        while (x % prime == 0) {",
        "            exponent++;",
        "            x /= prime;",
        "        }",
        "",
        "        factors.push_back({prime, exponent});",
        "    }",
        "",
        "    return factors;",
        "}"
    ],
    "description": "Prime factorization using SPF"
},"Segment Tree": {
    "scope": "cpp",
    "prefix": "segtree",
    "body": [
      "struct SegmentTree{",
      "",
      "    struct Node{",
      "",
      "        ll val;",
      "",
      "        Node(ll value = 0){",
      "            val = value;",
      "        }",
      "    };",
      "",
      "    ll n;",
      "    vector<Node> tree;",
      "",
      "    Node identity(){",
      "        return Node(0);",
      "    }",
      "",
      "    Node merge(Node left, Node right){",
      "        return Node(left.val + right.val);",
      "    }",
      "",
      "    Node make_node(ll value){",
      "        return Node(value);",
      "    }",
      "",
      "    void build(ll node, ll st, ll en, vector<ll>& arr){",
      "",
      "        if(st == en){",
      "            tree[node] = make_node(arr[st]);",
      "            return;",
      "        }",
      "",
      "        ll mid = (st + en) / 2;",
      "",
      "        build(2 * node, st, mid, arr);",
      "        build(2 * node + 1, mid + 1, en, arr);",
      "",
      "        tree[node] = merge(tree[2 * node], tree[2 * node + 1]);",
      "    }",
      "",
      "    Node query(ll node, ll st, ll en, ll l, ll r){",
      "",
      "        if(r < st || en < l)",
      "            return identity();",
      "",
      "        if(l <= st && en <= r)",
      "            return tree[node];",
      "",
      "        ll mid = (st + en) / 2;",
      "",
      "        return merge(",
      "            query(2 * node, st, mid, l, r),",
      "            query(2 * node + 1, mid + 1, en, l, r)",
      "        );",
      "    }",
      "",
      "    void update(ll node, ll st, ll en, ll idx, ll value){",
      "",
      "        if(st == en){",
      "            tree[node] = make_node(value);",
      "            return;",
      "        }",
      "",
      "        ll mid = (st + en) / 2;",
      "",
      "        if(idx <= mid)",
      "            update(2 * node, st, mid, idx, value);",
      "        else",
      "            update(2 * node + 1, mid + 1, en, idx, value);",
      "",
      "        tree[node] = merge(tree[2 * node], tree[2 * node + 1]);",
      "    }",
      "",
      "    ll kth(ll node, ll st, ll en, ll k){",
      "",
      "        if(st == en)",
      "            return st;",
      "",
      "        ll mid = (st + en) / 2;",
      "",
      "        if(tree[2 * node].val >= k)",
      "            return kth(2 * node, st, mid, k);",
      "",
      "        return kth(2 * node + 1, mid + 1, en, k - tree[2 * node].val);",
      "    }",
      "",
      "    SegmentTree(ll size = 0){",
      "        n = size;",
      "        tree.assign(4 * n + 5, identity());",
      "    }",
      "",
      "    void build(vector<ll>& arr){",
      "",
      "        n = arr.size();",
      "",
      "        tree.assign(4 * n + 5, identity());",
      "",
      "        if(n)",
      "            build(1, 0, n - 1, arr);",
      "    }",
      "",
      "    Node query(ll l, ll r){",
      "        return query(1, 0, n - 1, l, r);",
      "    }",
      "",
      "    void update(ll idx, ll value){",
      "        update(1, 0, n - 1, idx, value);",
      "    }",
      "",
      "    ll kth(ll k){",
      "",
      "        if(k <= 0 || tree[1].val < k)",
      "            return -1;",
      "",
      "        return kth(1, 0, n - 1, k);",
      "    }",
      "",
      "    ll size(){",
      "        return n;",
      "    }",
      "};",
      "",
      "/*",
      "EDIT POINTS",
      "1 -> Node",
      "2 -> Identity",
      "3 -> Merge",
      "4 -> Leaf Creation",
      "",
      "COMMANDS",
      "SegmentTree seg(n);",
      "seg.build(arr);",
      "seg.query(l,r).val;",
      "seg.update(idx,val);",
      "seg.kth(k);",
      "seg.size();",
      "*/"
    ],
    "description": "Generic Segment Tree with kth active bit"
  }
