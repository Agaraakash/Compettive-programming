"NCR Factorial Precompute": {
  "prefix": "ncr",
  "body": [
    "const ll MOD = 998244353;",
    "const ll N = 1000005;",
    "",
    "ll fact[N];",
    "ll invFact[N];",
    "",
    "ll power(ll a, ll b) {",
    "    ll res = 1;",
    "    while (b) {",
    "        if (b & 1) res = res * a % MOD;",
    "        a = a * a % MOD;",
    "        b >>= 1;",
    "    }",
    "    return res;",
    "}",
    "",
    "void initNCR() {",
    "    fact[0] = 1;",
    "    for (ll i = 1; i < N; i++)",
    "        fact[i] = fact[i - 1] * i % MOD;",
    "",
    "    invFact[N - 1] = power(fact[N - 1], MOD - 2);",
    "",
    "    for (ll i = N - 2; i >= 0; i--)",
    "        invFact[i] = invFact[i + 1] * (i + 1) % MOD;",
    "}",
    "",
    "ll nCr(ll n, ll r) {",
    "    if (r < 0 || r > n) return 0;",
    "    return fact[n] * invFact[r] % MOD * invFact[n - r] % MOD;",
    "}"
  ],
  "description": "Factorial + inverse factorial nCr precomputation"
},
"Build SPF": {
    "scope": "cpp",
    "prefix": "buildspf",
    "body": [
        "const ll MAXN = 500000;",
        "",
        "vector<ll> spf(MAXN + 1);",
        "",
        "void build_spf() {",
        "    for (ll i = 0; i <= MAXN; i++)",
        "        spf[i] = i;",
        "",
        "    for (ll i = 2; i * i <= MAXN; i++) {",
        "        if (spf[i] == i) {",
        "            for (ll j = i * i; j <= MAXN; j += i) {",
        "                if (spf[j] == j)",
        "                    spf[j] = i;",
        "            }",
        "        }",
        "    }",
        "}"
    ],
    "description": "Build SPF array"
},
"Factorize SPF": {
    "scope": "cpp",
    "prefix": "factorize",
    "body": [
        "vector<pair<ll,ll>> factorize(ll x) {",
        "    vector<pair<ll,ll>> factors;",
        "",
        "    while (x > 1) {",
        "        ll prime = spf[x];",
        "        ll exponent = 0;",
        "",
        "        while (x % prime == 0) {",
        "            exponent++;",
        "            x /= prime;",
        "        }",
        "",
        "        factors.push_back({prime, exponent});",
        "    }",
        "",
        "    return factors;",
        "}"
    ],
    "description": "Prime factorization using SPF"
